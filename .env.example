# ============================================
# CHRONOVAH FRONTEND - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# ====== API URL ======
# Development
VITE_API_URL=http://localhost:8000/api/v1

# Production (uncomment for production build)
# VITE_API_URL=https://api-chronovah-backend.onrender.com/api/v1

# ====== PAYSTACK ======
# Development - Use TEST public key (pk_test_xxx)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Production - Use LIVE public key (pk_live_xxx)
# VITE_PAYSTACK_PUBLIC_KEY=pk_live_your_live_public_key
